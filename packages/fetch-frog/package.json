{
	"name": "fetch-frog",
	"description": "Type safe api clients using OpenApi Spec",
	"version": "0.0.1",
	"private": false,
	"type": "module",
	"scripts": {
		"generate": "openapi-typescript",
		"cli:convert": "node ./bin/script.js convert",
		"cli:generate": "node ./bin/script.js generate",
		"test": "pnpm test:types && vitest run",
		"test:types": "tsc -p tsconfig.json --noEmit",
		"coverage": "vitest run --coverage",
		"build": "tsc -p tsconfig.build.json"
	},
	"bin": {
		"fetch-frog": "./bin/script.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.js"
		}
	},
	"files": [
		"dist/**",
		"bin"
	],
	"devDependencies": {
		"@vitest/coverage-v8": "3.2.4",
		"typescript": "^5.0.0",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"defu": "^6.1.4",
		"ofetch": "^1.4.1",
		"openapi-typescript": "6.7.5",
		"openapi-typescript-helpers": "^0.0.7",
		"swagger2openapi": "^7.0.8",
		"yargs-parser": "^21.1.1"
	},
	"publishConfig": {
		"access": "public"
	}
}
