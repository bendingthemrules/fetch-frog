{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "node",
		"declaration": false,
		"maxNodeModuleJsDepth": 0
	},
	"include": ["*.js", "types/**/*.d.ts"],
	"exclude": ["bin", "**/*.test.ts", "test/**/*", "node_modules"]
}
