{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"maxNodeModuleJsDepth": 0
	},
	"include": ["*.ts", "types/**/*.ts", "types/**/*.d.ts"],
	"exclude": ["bin", "**/*.test.ts", "test/**/*", "node_modules"]
}
