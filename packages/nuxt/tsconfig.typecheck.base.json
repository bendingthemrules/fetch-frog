// Shared base for the per-Nuxt-version type-checks. Extended by
// tsconfig.typecheck.nuxt3.json / tsconfig.typecheck.nuxt4.json — do not run
// directly: it has no `nuxt` paths remap, so it would resolve the ambient nuxt.
{
	"compilerOptions": {
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"target": "ESNext",
		"module": "Preserve",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"types": []
	},
	"include": ["index.ts", "use-fetch.ts", "utils.ts", "types/**/*.ts", "use-fetch.test-d.ts"],
	"exclude": ["node_modules", "playground", "**/*.test.ts"]
}
