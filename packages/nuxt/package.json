{
	"name": "@fetch-frog/nuxt",
	"version": "0.1.0-beta.4",
	"private": false,
	"description": "Nuxt specific implementation of fetch-frog",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bendingthemrules/fetch-frog",
		"directory": "packages/nuxt"
	},
	"files": [
		"index.ts",
		"use-fetch.ts",
		"utils.ts",
		"types"
	],
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt --write .",
		"fmt:check": "oxfmt --check .",
		"test:types:nuxt3": "tsc -p tsconfig.typecheck.nuxt3.json",
		"test:types:nuxt4": "tsc -p tsconfig.typecheck.nuxt4.json",
		"test:types": "pnpm test:types:nuxt3 && pnpm test:types:nuxt4",
		"test": "pnpm test:types && vitest --run"
	},
	"dependencies": {
		"defu": "catalog:",
		"fetch-frog": "workspace:*"
	},
	"devDependencies": {
		"@nuxt/test-utils": "^3.14.0",
		"@vue/test-utils": "^2.4.6",
		"happy-dom": "^20.0.0",
		"nuxt": "^3.13.0",
		"nuxt3": "npm:nuxt@^3.13.0",
		"nuxt4": "npm:nuxt@^4.0.0",
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"typescript": "^5.0.0",
		"vitest": "catalog:",
		"vue": "^3.5.0"
	},
	"peerDependencies": {
		"nuxt": "^3.0.0 || ^4.0.0",
		"vue": "^3.0.0"
	}
}
